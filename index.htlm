<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Control Anuales Sociedades — San Miguel Contadores</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:system-ui,sans-serif;background:#f0f0ee;color:#111;min-height:100vh}
#login-screen{display:flex;align-items:center;justify-content:center;min-height:100vh;padding:20px}
.login-box{background:#f5f5f3;border:0.5px solid #ddd;border-radius:10px;padding:40px;max-width:380px;width:100%;text-align:center}
.login-box h2{color:#185FA5;font-size:20px;font-weight:600;margin-bottom:4px}
.login-box p{color:#555;font-size:13px;margin-bottom:24px}
.login-box input{width:100%;border:1px solid #ddd;border-radius:6px;padding:10px 12px;font-size:14px;margin-bottom:12px;background:#fff}
.login-box button{background:#185FA5;color:#fff;border:none;border-radius:6px;padding:10px 24px;font-size:14px;font-weight:600;cursor:pointer;width:100%}
.login-box button:hover{background:#0C447C}
.login-box .error{color:#721c24;font-size:12px;margin-top:8px;min-height:18px}
#app{display:none}
.header{background:#185FA5;color:#fff;padding:14px 24px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;flex-wrap:wrap;gap:8px}
.header-title{font-size:17px;font-weight:600}
.header-sub{font-size:11px;opacity:.8;margin-top:1px}
.header-right{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.role-badge{padding:3px 10px;border-radius:6px;font-size:10px;font-weight:600}
.role-admin{background:rgba(255,255,255,.25);color:#fff}
.role-read{background:#FFF8EC;color:#854F0B}
.yr-btn{background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.3);border-radius:6px;color:#fff;padding:4px 10px;font-size:11px;font-weight:600;cursor:pointer}
.nav{display:flex;gap:2px;background:#fff;border-bottom:1px solid #ddd;padding:0 12px;overflow-x:auto;position:sticky;top:52px;z-index:99}
.nav button{padding:10px 14px;border:none;background:transparent;color:#555;cursor:pointer;font-size:12px;font-weight:600;border-radius:6px 6px 0 0;white-space:nowrap;margin-top:4px}
.nav button.active{background:#185FA5;color:#fff}
.content{padding:16px 20px;max-width:1400px;margin:0 auto}
.stitle{margin:0 0 14px;font-size:16px;font-weight:600;color:#185FA5;border-bottom:2px solid #185FA5;padding-bottom:8px}
.card{background:#f5f5f3;border:0.5px solid #ddd;border-radius:10px;padding:16px;margin-bottom:12px}
.kpi-row{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:16px}
.kpi{flex:1 1 130px;border:0.5px solid #ddd;border-radius:10px;padding:12px 16px;text-align:center;min-width:110px}
.kpi-num{font-size:28px;font-weight:600}
.kpi-label{font-size:11px;color:#555;margin-top:2px}
table{width:100%;border-collapse:collapse;font-size:12px}
th{text-align:left;padding:8px 10px;border-bottom:2px solid #185FA5;font-weight:600;font-size:11px;color:#185FA5;white-space:nowrap;background:#f0f0ee}
td{padding:7px 10px;border-bottom:1px solid #e8e8e6;vertical-align:middle}
.badge{display:inline-block;padding:1px 6px;border-radius:6px;font-size:10px;font-weight:600;white-space:nowrap}
.badge-p{background:#d4edda;color:#155724;border:1px solid #a3d5b0}
.badge-a{background:#f8d7da;color:#721c24;border:1px solid #f1aeb5}
.badge-nc{background:#e9ecef;color:#6c757d;border:1px solid #ced4da}
.badge-sd{background:#f5f5f3;color:#888;border:1px solid #ddd}
.badge-ep{background:#FFF8EC;color:#854F0B;border:1px solid #EF9F27}
.badge-t{background:#d4edda;color:#155724;border:1px solid #a3d5b0}
.urg-v{background:#721c24;color:#fff}.urg-u{background:#f8d7da;color:#721c24}.urg-p{background:#FFF8EC;color:#854F0B}.urg-ok{background:#d4edda;color:#155724}
input[type="text"],input[type="number"],input[type="password"]{border:1px solid #ddd;border-radius:6px;padding:5px 8px;font-size:12px;background:#fff;box-sizing:border-box}
select{border:1px solid #ddd;border-radius:6px;padding:4px 5px;font-size:11px;background:#fff;cursor:pointer}
.date-input{border:1px solid #ddd;border-radius:6px;padding:5px 8px;font-size:12px;background:#fff;width:120px;text-align:center;letter-spacing:1px}
.btn{background:#185FA5;color:#fff;border:none;border-radius:6px;padding:7px 16px;font-size:12px;font-weight:600;cursor:pointer}
.btn:hover{background:#0C447C}
.btn-s{background:transparent;color:#185FA5;border:1px solid #185FA5;border-radius:6px;padding:5px 12px;font-size:11px;font-weight:600;cursor:pointer}
.btn-d{background:#dc3545;color:#fff;border:none;border-radius:6px;padding:5px 12px;font-size:11px;font-weight:600;cursor:pointer}
.filter-bar{display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-bottom:14px}
.filter-bar input{max-width:240px}
.obl-tabs{display:flex;gap:4px;margin-bottom:14px;flex-wrap:wrap}
.obl-tab{border:1px solid #ddd;border-radius:6px;padding:6px 12px;font-size:11px;font-weight:400;background:#fff;color:#555;cursor:pointer}
.obl-tab.active{background:#185FA5;color:#fff;border-color:#185FA5;font-weight:600}
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.5);display:flex;align-items:center;justify-content:center;z-index:200;padding:20px}
.modal-box{background:#fff;border-radius:12px;padding:24px;max-width:540px;width:100%;max-height:90vh;overflow-y:auto}
.modal-box h3{margin:0 0 16px;font-size:16px}
.form-row{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:10px}
.form-group{display:flex;flex-direction:column;gap:3px}
.form-group label{font-size:11px;font-weight:600;color:#555}
.wf-box{margin-top:12px;padding:12px;background:#E6F1FB;border-radius:8px;border:1px solid #85B7EB}
.wf-title{font-size:12px;font-weight:600;color:#0C447C;margin-bottom:8px}
.wf-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:6px}
.wf-item{background:#fff;border-radius:6px;padding:6px 8px;border:0.5px solid #85B7EB}
.wf-item label{font-size:10px;color:#0C447C;font-weight:600}
.cm-box{margin-top:12px;padding:12px;background:#F3EEFB;border-radius:8px;border:1px solid #C3A8E8}
.cm-title{font-size:12px;font-weight:600;color:#4A2D8A;margin-bottom:6px}
.note-box{margin-top:8px;padding:6px 10px;background:#FFF8EC;border:1px solid #EF9F27;border-radius:6px;font-size:11px;color:#854F0B}
.clickable{cursor:pointer}.clickable:hover{background:#e8e8e6}
.trunc{max-width:180px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.progress-bar{display:flex;align-items:center;gap:4px}
.progress-track{flex:1;height:6px;background:#e9ecef;border-radius:3px;overflow:hidden}
.progress-fill{height:100%;border-radius:3px}
.ml-auto{margin-left:auto}
.status-sel{border-radius:6px;font-weight:600;padding:2px 4px;font-size:10px}
.back-btn{background:none;border:none;color:#185FA5;cursor:pointer;font-size:13px;font-weight:600;padding:0;margin-bottom:12px}
.det-header{border-left:4px solid #185FA5;display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:12px}
.det-header h2{margin:0;font-size:18px;color:#185FA5}
.det-header .sub{font-size:12px;color:#555;margin-top:4px}
.hist-row{display:flex;gap:6px;margin-top:3px}.hist-col{text-align:center}.hist-col .yr{font-size:10px;color:#888;margin-bottom:2px}
.readonly-msg{background:#FFF8EC;border:1px solid #EF9F27;border-radius:8px;padding:8px 14px;font-size:12px;color:#854F0B;margin-bottom:14px;text-align:center}
@media(max-width:768px){.content{padding:12px}.header{padding:10px 16px}.kpi{flex:1 1 100px;padding:8px 10px}.kpi-num{font-size:22px}}
@media print{#login-screen,.nav,.header,.filter-bar,.btn,.btn-s,.btn-d,.obl-tabs,.back-btn,.readonly-msg{display:none!important}#app{display:block!important}.content{padding:0}}
</style>
</head>
<body>
<div id="login-screen">
<div class="login-box">
<h2>San Miguel Contadores</h2>
<p>Control Anuales Sociedades</p>
<input type="password" id="pwd-input" placeholder="Contraseña" onkeydown="if(event.key==='Enter')checkPwd()">
<button onclick="checkPwd()">Ingresar</button>
<div class="error" id="pwd-error"></div>
</div>
</div>
<div id="app">
<div class="header">
<div><div class="header-title">San Miguel Contadores</div><div class="header-sub" id="header-sub"></div></div>
<div class="header-right"><span class="role-badge" id="role-badge"></span><button class="yr-btn" id="yr-btn" onclick="openYrCfg()"></button><div style="font-size:11px;opacity:.8" id="header-date"></div></div>
</div>
<div class="nav" id="nav"></div>
<div class="content" id="main-content"></div>
</div>
<div class="modal-bg" id="modal-bg" style="display:none" onclick="closeModal()">
<div class="modal-box" id="modal-box" onclick="event.stopPropagation()"></div>
</div>
<script>
/* ─── Auth ─── */
const PWD_ADMIN="SanMiguel2026!";
const PWD_READ="consulta2026";
let isAdmin=false;
function checkPwd(){
  const v=document.getElementById('pwd-input').value;
  if(v===PWD_ADMIN){isAdmin=true;document.getElementById('login-screen').style.display='none';document.getElementById('app').style.display='block';init()}
  else if(v===PWD_READ){isAdmin=false;document.getElementById('login-screen').style.display='none';document.getElementById('app').style.display='block';init()}
  else{document.getElementById('pwd-error').textContent='Contraseña incorrecta.';document.getElementById('pwd-input').value=''}
}

/* ─── Constants ─── */
const ANALYSTS=["YANINA ALARCON","BRIAN VALDEZ","MELINA PLASTANO","ALBINO BARRIOS"];
const OBLS=["ganancias","bsPersonales","balanceARCA","cm05","regInfPartSoc","djIBCABA","djIBBsAs"];
const OLBL={ganancias:"Imp. Ganancias",bsPersonales:"Bs.Pers. Resp.Sust.",balanceARCA:"Balance ARCA",cm05:"CM05",regInfPartSoc:"Reg.Inf.Part.Soc.",djIBCABA:"DJ IB CABA",djIBBsAs:"DJ IB Bs.As."};
const WFSTEPS=["AxI Estático","Pagos a cuenta","Recepción Balance","Análisis Balance","AxI Dinámico","Ajustes Impositivos","Carga DJ","Control DJ"];
const STATS=["","PRESENTADA","ADEUDADA","N/C"];
const WFST=["","EN PROCESO","TERMINADO"];
const IBOPS=["CM","Local CABA","Local Bs As","No inscripta"];
const TODAY=new Date().toISOString().slice(0,10);

/* ─── Helpers ─── */
const fmtD=d=>{if(!d||d==="N/C")return d||"—";const p=d.split("-");return p[2]+"/"+p[1]+"/"+p[0]};
const daysTo=d=>{if(!d||d==="N/C")return 9999;return Math.ceil((new Date(d)-new Date(TODAY))/864e5)};
const badgeCls=s=>s==="PRESENTADA"?"badge-p":s==="ADEUDADA"?"badge-a":s==="N/C"?"badge-nc":s==="EN PROCESO"?"badge-ep":s==="TERMINADO"?"badge-t":"badge-sd";
const badge=s=>'<span class="badge '+badgeCls(s)+'">'+(s||"SIN DATO")+'</span>';
const urgCls=d=>d<0?"urg-v":d<=7?"urg-u":d<=30?"urg-p":"urg-ok";
const urgLbl=d=>d<0?"VENCIDO":d<=7?"URGENTE":"PRÓXIMO";
const eo=h=>{const y={};h.forEach(yr=>y[yr]="");return{d:"",y,cs:"",nt:""}};
const nO=h=>({ganancias:{...eo(h),wf:["","","","","","","",""]},bsPersonales:eo(h),balanceARCA:eo(h),cm05:{...eo(h),co:""},regInfPartSoc:eo(h),djIBCABA:eo(h),djIBBsAs:eo(h)});

/* Date helpers: DD/MM/AAAA <-> YYYY-MM-DD */
function dateToDisplay(iso){if(!iso||iso==="N/C")return"";const p=iso.split("-");return p[2]+"/"+p[1]+"/"+p[0]}
function displayToDate(txt){if(!txt)return"";const p=txt.replace(/[^0-9]/g,"/").split("/").filter(x=>x);if(p.length===3&&p[0].length<=2&&p[1].length<=2&&p[2].length===4){const d=p[0].padStart(2,"0"),m=p[1].padStart(2,"0");return p[2]+"-"+m+"-"+d}return""}
function handleDateInput(el,cid,ok){
  let v=el.value.replace(/[^0-9/]/g,"");
  if(v.length===2&&!v.includes("/"))v+="/";
  if(v.length===5&&v.split("/").length===2)v+="/";
  el.value=v;
}

/* ─── Confirm helper ─── */
function confirmAndRun(msg,fn){if(!isAdmin)return;if(confirm(msg)){fn()}}

/* ─── Initial Data ─── */
const INIT_DATA=[
{id:1,n:"AC SERVICIOS SAU",a:"YANINA ALARCON",c:8,m:12,ib:"CM",o:{ganancias:{d:"2026-05-15",y:{2024:"ADEUDADA",2023:"ADEUDADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"PRESENTADA",nt:"",wf:["","","","","","","",""]},bsPersonales:{d:"2026-06-16",y:{2024:"ADEUDADA",2023:"ADEUDADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"PRESENTADA",nt:"Faltan balances."},balanceARCA:{d:"2026-06-30",y:{2024:"ADEUDADA",2023:"ADEUDADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"PRESENTADA",nt:""},cm05:{d:"2026-06-30",y:{2024:"ADEUDADA",2023:"ADEUDADA",2022:"ADEUDADA",2021:"ADEUDADA"},cs:"PRESENTADA",nt:"Adeudan desde 2020.",co:""},regInfPartSoc:{d:"2026-07-30",y:{2024:"ADEUDADA",2023:"PRESENTADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"PRESENTADA",nt:""},djIBCABA:{d:"N/C",y:{2024:"N/C",2023:"N/C",2022:"N/C",2021:"N/C"},cs:"PRESENTADA",nt:""},djIBBsAs:{d:"N/C",y:{2024:"N/C",2023:"N/C",2022:"N/C",2021:"N/C"},cs:"PRESENTADA",nt:""}}},
{id:2,n:"ALTERNATIVA SUR SRL",a:"YANINA ALARCON",c:3,m:12,ib:"CM",o:{ganancias:{d:"2026-05-13",y:{2024:"PRESENTADA",2023:"PRESENTADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"ADEUDADA",nt:"",wf:["","","","","","","",""]},bsPersonales:{d:"2026-06-11",y:{2024:"PRESENTADA",2023:"PRESENTADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"ADEUDADA",nt:""},balanceARCA:{d:"2026-06-30",y:{2024:"PRESENTADA",2023:"PRESENTADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"ADEUDADA",nt:""},cm05:{d:"2026-06-30",y:{2024:"ADEUDADA",2023:"ADEUDADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"ADEUDADA",nt:"",co:""},regInfPartSoc:{d:"2026-07-28",y:{2024:"PRESENTADA",2023:"PRESENTADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"ADEUDADA",nt:""},djIBCABA:{d:"N/C",y:{2024:"N/C",2023:"N/C",2022:"N/C",2021:"N/C"},cs:"ADEUDADA",nt:""},djIBBsAs:{d:"N/C",y:{2024:"N/C",2023:"N/C",2022:"N/C",2021:"N/C"},cs:"ADEUDADA",nt:""}}},
{id:3,n:"ANSER INDICUS",a:"MELINA PLASTANO",c:3,m:12,ib:"CM",o:{ganancias:{d:"2026-05-13",y:{2024:"PRESENTADA",2023:"PRESENTADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"N/C",nt:"",wf:["","","","","","","",""]},bsPersonales:{d:"2026-06-11",y:{2024:"",2023:"",2022:"",2021:""},cs:"N/C",nt:""},balanceARCA:{d:"2026-06-30",y:{2024:"",2023:"",2022:"",2021:""},cs:"N/C",nt:""},cm05:{d:"2026-06-30",y:{2024:"N/C",2023:"N/C",2022:"N/C",2021:"N/C"},cs:"N/C",nt:"Lo presenta la empresa.",co:"N/C"},regInfPartSoc:{d:"2026-07-28",y:{2024:"PRESENTADA",2023:"PRESENTADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"N/C",nt:""},djIBCABA:{d:"N/C",y:{2024:"N/C",2023:"N/C",2022:"N/C",2021:"N/C"},cs:"N/C",nt:""},djIBBsAs:{d:"N/C",y:{2024:"N/C",2023:"N/C",2022:"N/C",2021:"N/C"},cs:"N/C",nt:""}}},
{id:4,n:"BAKORIS SA",a:"YANINA ALARCON",c:3,m:12,ib:"CM",o:{ganancias:{d:"2026-05-13",y:{2024:"PRESENTADA",2023:"PRESENTADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"",nt:"",wf:["","","","","","","",""]},bsPersonales:{d:"2026-06-11",y:{2024:"",2023:"",2022:"",2021:""},cs:"",nt:""},balanceARCA:{d:"2026-06-30",y:{2024:"",2023:"",2022:"",2021:""},cs:"",nt:""},cm05:{d:"2026-06-30",y:{2024:"PRESENTADA",2023:"PRESENTADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"",nt:"",co:""},regInfPartSoc:{d:"2026-07-28",y:{2024:"",2023:"",2022:"",2021:""},cs:"",nt:""},djIBCABA:{d:"N/C",y:{2024:"N/C",2023:"N/C",2022:"N/C",2021:"N/C"},cs:"",nt:""},djIBBsAs:{d:"N/C",y:{2024:"N/C",2023:"N/C",2022:"N/C",2021:"N/C"},cs:"",nt:""}}},
{id:5,n:"CATALDI VIDART S.R.L.",a:"BRIAN VALDEZ",c:5,m:12,ib:"CM",o:{ganancias:{d:"2025-05-14",y:{2024:"N/C",2023:"N/C",2022:"N/C",2021:"N/C"},cs:"",nt:"Primer ejercicio.",wf:["","","","","","","",""]},bsPersonales:{d:"2026-06-12",y:{2024:"N/C",2023:"N/C",2022:"N/C",2021:"N/C"},cs:"",nt:""},balanceARCA:{d:"2026-06-30",y:{2024:"N/C",2023:"N/C",2022:"N/C",2021:"N/C"},cs:"",nt:""},cm05:{d:"2026-06-30",y:{2024:"N/C",2023:"N/C",2022:"N/C",2021:"N/C"},cs:"",nt:"",co:""},regInfPartSoc:{d:"2026-07-30",y:{2024:"N/C",2023:"N/C",2022:"N/C",2021:"N/C"},cs:"",nt:""},djIBCABA:{d:"N/C",y:{2024:"N/C",2023:"N/C",2022:"N/C",2021:"N/C"},cs:"",nt:""},djIBBsAs:{d:"N/C",y:{2024:"N/C",2023:"N/C",2022:"N/C",2021:"N/C"},cs:"",nt:""}}},
{id:6,n:"CENTRO ARG. UROLOGIA SA",a:"YANINA ALARCON",c:8,m:12,ib:"CM",o:{ganancias:{d:"2026-05-15",y:{2024:"",2023:"",2022:"",2021:""},cs:"",nt:"",wf:["","","","","","","",""]},bsPersonales:{d:"2026-06-16",y:{2024:"",2023:"",2022:"",2021:""},cs:"",nt:""},balanceARCA:{d:"2026-06-30",y:{2024:"",2023:"",2022:"",2021:""},cs:"",nt:""},cm05:{d:"N/C",y:{2024:"N/C",2023:"N/C",2022:"N/C",2021:"N/C"},cs:"",nt:"",co:"N/C"},regInfPartSoc:{d:"2026-07-30",y:{2024:"",2023:"",2022:"",2021:""},cs:"",nt:""},djIBCABA:{d:"2026-09-24",y:{2024:"",2023:"",2022:"",2021:""},cs:"",nt:""},djIBBsAs:{d:"N/C",y:{2024:"N/C",2023:"N/C",2022:"N/C",2021:"N/C"},cs:"",nt:""}}},
