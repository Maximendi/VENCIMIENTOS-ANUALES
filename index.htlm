{id:32,n:"SERVICES TECHNIQUES SAS",a:"YANINA ALARCON",c:9,m:12,ib:"CM",o:{ganancias:{d:"2026-05-15",y:{2024:"PRESENTADA",2023:"PRESENTADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"",nt:"",wf:["","","","","","","",""]},bsPersonales:{d:"2026-06-16",y:{2024:"",2023:"",2022:"",2021:""},cs:"",nt:""},balanceARCA:{d:"2026-06-30",y:{2024:"PRESENTADA",2023:"PRESENTADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"",nt:""},cm05:{d:"N/C",y:{2024:"N/C",2023:"N/C",2022:"N/C",2021:"N/C"},cs:"",nt:"",co:""},regInfPartSoc:{d:"2026-07-30",y:{2024:"ADEUDADA",2023:"ADEUDADA",2022:"ADEUDADA",2021:"ADEUDADA"},cs:"",nt:"Regularizar."},djIBCABA:{d:"2026-09-24",y:{2024:"",2023:"",2022:"",2021:""},cs:"",nt:""},djIBBsAs:{d:"N/C",y:{2024:"N/C",2023:"N/C",2022:"N/C",2021:"N/C"},cs:"",nt:""}}},
{id:33,n:"SMART LABS SA",a:"MELINA PLASTANO",c:2,m:12,ib:"Local Bs As",o:{ganancias:{d:"2026-05-13",y:{2024:"PRESENTADA",2023:"PRESENTADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"",nt:"",wf:["","","","","","","",""]},bsPersonales:{d:"2026-06-11",y:{2024:"PRESENTADA",2023:"PRESENTADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"",nt:""},balanceARCA:{d:"2026-06-30",y:{2024:"ADEUDADA",2023:"PRESENTADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"",nt:"Presentar 2024."},cm05:{d:"N/C",y:{2024:"N/C",2023:"N/C",2022:"N/C",2021:"N/C"},cs:"",nt:"",co:"N/C"},regInfPartSoc:{d:"2026-07-28",y:{2024:"ADEUDADA",2023:"ADEUDADA",2022:"ADEUDADA",2021:"ADEUDADA"},cs:"",nt:"Regularizar."},djIBCABA:{d:"2026-09-21",y:{2024:"",2023:"",2022:"",2021:""},cs:"",nt:""},djIBBsAs:{d:"N/C",y:{2024:"N/C",2023:"N/C",2022:"N/C",2021:"N/C"},cs:"",nt:""}}},
{id:34,n:"SUNSET TIRES",a:"BRIAN VALDEZ",c:9,m:12,ib:"Local CABA",o:{ganancias:{d:"2026-05-15",y:{2024:"PRESENTADA",2023:"PRESENTADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"",nt:"",wf:["","","","","","","",""]},bsPersonales:{d:"2026-06-16",y:{2024:"PRESENTADA",2023:"PRESENTADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"",nt:""},balanceARCA:{d:"2026-06-30",y:{2024:"",2023:"",2022:"",2021:""},cs:"",nt:""},cm05:{d:"2026-06-30",y:{2024:"PRESENTADA",2023:"PRESENTADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"",nt:"",co:""},regInfPartSoc:{d:"2026-07-30",y:{2024:"PRESENTADA",2023:"PRESENTADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"",nt:""},djIBCABA:{d:"N/C",y:{2024:"N/C",2023:"N/C",2022:"N/C",2021:"N/C"},cs:"",nt:""},djIBBsAs:{d:"N/C",y:{2024:"N/C",2023:"N/C",2022:"N/C",2021:"N/C"},cs:"",nt:""}}},
{id:35,n:"TEEJET TECHNOLOGIES SRL",a:"MELINA PLASTANO",c:9,m:12,ib:"CM",o:{ganancias:{d:"2026-05-15",y:{2024:"PRESENTADA",2023:"PRESENTADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"",nt:"",wf:["","","","","","","",""]},bsPersonales:{d:"2026-06-16",y:{2024:"",2023:"",2022:"",2021:""},cs:"",nt:""},balanceARCA:{d:"2026-06-30",y:{2024:"PRESENTADA",2023:"PRESENTADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"",nt:""},cm05:{d:"2026-06-30",y:{2024:"ADEUDADA",2023:"PRESENTADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"",nt:"Regularizar.",co:""},regInfPartSoc:{d:"2026-07-30",y:{2024:"PRESENTADA",2023:"PRESENTADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"",nt:""},djIBCABA:{d:"N/C",y:{2024:"N/C",2023:"N/C",2022:"N/C",2021:"N/C"},cs:"",nt:""},djIBBsAs:{d:"N/C",y:{2024:"N/C",2023:"N/C",2022:"N/C",2021:"N/C"},cs:"",nt:""}}},
{id:36,n:"TOKKEN LABS SAS",a:"YANINA ALARCON",c:7,m:12,ib:"CM",o:{ganancias:{d:"2026-05-15",y:{2024:"PRESENTADA",2023:"PRESENTADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"",nt:"",wf:["","","","","","","",""]},bsPersonales:{d:"2026-06-16",y:{2024:"PRESENTADA",2023:"PRESENTADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"",nt:""},balanceARCA:{d:"2026-06-30",y:{2024:"PRESENTADA",2023:"PRESENTADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"",nt:""},cm05:{d:"2026-06-30",y:{2024:"PRESENTADA",2023:"PRESENTADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"",nt:"",co:""},regInfPartSoc:{d:"2026-07-30",y:{2024:"ADEUDADA",2023:"PRESENTADA",2022:"PRESENTADA",2021:"PRESENTADA"},cs:"",nt:"Regularizar."},djIBCABA:{d:"N/C",y:{2024:"N/C",2023:"N/C",2022:"N/C",2021:"N/C"},cs:"",nt:""},djIBBsAs:{d:"N/C",y:{2024:"N/C",2023:"N/C",2022:"N/C",2021:"N/C"},cs:"",nt:""}}}
];
/* ─── State ─── */
let S={clients:null,years:{cur:2025,hist:[2024,2023,2022,2021]},view:"dashboard",selId:null,filtA:"",filtS:"",search:"",oblF:"ganancias",dashFilt:""};
function load(){try{const d=JSON.parse(localStorage.getItem("smca_v2"));if(d){S.clients=d.clients;S.years=d.years||S.years}}catch(e){}if(!S.clients)S.clients=JSON.parse(JSON.stringify(INIT_DATA))}
function persist(){try{localStorage.setItem("smca_v2",JSON.stringify({clients:S.clients,years:S.years}))}catch(e){}}

/* ─── Render ─── */
function render(){
  document.getElementById("header-sub").textContent="Control Anuales Sociedades "+S.years.cur;
  document.getElementById("header-date").textContent="Hoy: "+fmtD(TODAY);
  const yb=document.getElementById("yr-btn");
  yb.textContent="Años: "+S.years.cur+" ("+S.years.hist.join(", ")+")";
  yb.style.display=isAdmin?"inline-block":"none";
  const rb=document.getElementById("role-badge");
  rb.textContent=isAdmin?"ADMINISTRADOR":"SOLO LECTURA";
  rb.className="role-badge "+(isAdmin?"role-admin":"role-read");
  renderNav();
  const m=document.getElementById("main-content");
  const rdMsg=isAdmin?"":'<div class="readonly-msg">Modo consulta — los cambios requieren acceso de administrador</div>';
  if(S.view==="dashboard")m.innerHTML=rdMsg+vDash();
  else if(S.view==="clientes")m.innerHTML=rdMsg+vCl();
  else if(S.view==="detail")m.innerHTML=rdMsg+vDet();
  else if(S.view==="obligacion")m.innerHTML=rdMsg+vObl();
  else if(S.view==="vencimientos")m.innerHTML=rdMsg+vVto();
  else if(S.view==="workflow")m.innerHTML=rdMsg+vWf();
  else if(S.view==="analistas")m.innerHTML=rdMsg+vAn();
}
function renderNav(){const tabs=[["dashboard","Dashboard"],["clientes","Clientes"],["obligacion","Obligación"],["vencimientos","Vencimientos"],["workflow","Workflow"],["analistas","Analistas"]];document.getElementById("nav").innerHTML=tabs.map(([k,l])=>'<button class="'+(S.view===k||(S.view==="detail"&&k==="clientes")?"active":"")+'" onclick="go(\''+k+'\')">'+l+'</button>').join("")}
function go(v){S.view=v;render()}
function goDetail(id){S.selId=id;S.view="detail";render()}
function closeModal(){document.getElementById("modal-bg").style.display="none"}
function openModal(html){document.getElementById("modal-box").innerHTML=html;document.getElementById("modal-bg").style.display="flex"}

/* ─── Computed ─── */
function getDeadlines(){const r=[];S.clients.forEach(c=>{OBLS.forEach(k=>{const o=c.o[k];if(!o||o.d==="N/C"||!o.d)return;if(o.cs==="PRESENTADA"||o.cs==="N/C")return;const d=daysTo(o.d);if(d<=60)r.push({cn:c.n,a:c.a,ol:OLBL[k],dt:o.d,d,cs:o.cs,id:c.id})})});return r.sort((a,b)=>a.d-b.d)}
function getStats(){let p=0,a=0,s=0;S.clients.forEach(c=>{OBLS.forEach(k=>{const v=c.o[k]?.cs;if(v==="PRESENTADA")p++;else if(v==="ADEUDADA")a++;else if(v!=="N/C")s++})});const dl=getDeadlines();return{p,a,s,v:dl.filter(d=>d.d<0).length,p7:dl.filter(d=>d.d>=0&&d.d<=7).length}}
function getFiltered(){return S.clients.filter(c=>{if(S.search&&!c.n.toLowerCase().includes(S.search.toLowerCase()))return false;if(S.filtA&&c.a!==S.filtA)return false;if(S.filtS&&!OBLS.some(k=>c.o[k]?.cs===S.filtS))return false;return true})}

/* ─── Mutation with confirm ─── */
function updO(cid,ok,f,v){const c=S.clients.find(x=>x.id===cid);if(c){c.o[ok][f]=v;persist();render()}}
function updH(cid,ok,yr,v){const c=S.clients.find(x=>x.id===cid);if(c){if(!c.o[ok].y)c.o[ok].y={};c.o[ok].y[yr]=v;persist();render()}}
function updWf(cid,i,v){const c=S.clients.find(x=>x.id===cid);if(c){c.o.ganancias.wf[i]=v;persist();render()}}
function updC(cid,f,v){const c=S.clients.find(x=>x.id===cid);if(c){c[f]=v;persist();render()}}
/* Wrappers with confirmation */
function cUpdO(cid,ok,f,v,lbl){if(!isAdmin)return;confirmAndRun("¿Cambiar "+lbl+" a "+(v||"Sin dato")+"?",()=>updO(cid,ok,f,v))}
function cUpdH(cid,ok,yr,v){if(!isAdmin)return;confirmAndRun("¿Cambiar estado "+yr+" a "+(v||"Sin dato")+"?",()=>updH(cid,ok,yr,v))}
function cUpdWf(cid,i,v){if(!isAdmin)return;confirmAndRun("¿Cambiar paso "+(i+1)+" a "+(v||"Pendiente")+"?",()=>updWf(cid,i,v))}
function cUpdNote(cid,ok,el){if(!isAdmin)return;confirmAndRun("¿Guardar nota?",()=>updO(cid,ok,"nt",el.value))}
function cToggleNC(cid,ok,toNC){if(!isAdmin)return;confirmAndRun(toNC?"¿Marcar como N/C?":"¿Habilitar fecha?",()=>updO(cid,ok,"d",toNC?"N/C":""))}

function addClient(){if(!isAdmin)return;const n=document.getElementById("add-n").value;if(!n)return;if(!confirm("¿Agregar cliente "+n+"?"))return;const c={id:Math.max(...S.clients.map(x=>x.id),0)+1,n,a:document.getElementById("add-a").value,c:parseInt(document.getElementById("add-c").value)||0,m:parseInt(document.getElementById("add-m").value)||12,ib:document.getElementById("add-ib").value,o:nO(S.years.hist)};S.clients.push(c);persist();closeModal();render()}
function delClient(id){if(!isAdmin)return;const c=S.clients.find(x=>x.id===id);if(!confirm("¿Eliminar a "+c.n+"? No se puede deshacer."))return;S.clients=S.clients.filter(x=>x.id!==id);if(S.selId===id){S.selId=null;S.view="clientes"}persist();closeModal();render()}
function saveYears(){if(!isAdmin)return;if(!confirm("¿Guardar configuración de años?"))return;S.years.cur=parseInt(document.getElementById("yr-cur").value)||2025;S.years.hist=[0,1,2,3].map(i=>parseInt(document.getElementById("yr-h"+i).value)||2020);persist();closeModal();render()}
function cUpdCl(cid,f,v,lbl){if(!isAdmin)return;confirmAndRun("¿Cambiar "+lbl+"?",()=>updC(cid,f,v))}
/* ─── Modals ─── */
function openAddModal(){if(!isAdmin)return;openModal('<h3 style="color:#185FA5">Agregar Cliente</h3><div class="form-row"><div class="form-group" style="flex:1 1 100%"><label>Razón Social</label><input type="text" id="add-n" style="width:100%"></div></div><div class="form-row"><div class="form-group" style="flex:1 1 150px"><label>Analista</label><select id="add-a" style="width:100%">'+ANALYSTS.map(a=>'<option>'+a+'</option>').join('')+'</select></div><div class="form-group" style="flex:0 0 70px"><label>CUIT</label><input type="number" id="add-c" value="0" min="0" max="9" style="width:100%"></div><div class="form-group" style="flex:0 0 70px"><label>Cierre</label><input type="number" id="add-m" value="12" min="1" max="12" style="width:100%"></div><div class="form-group" style="flex:1 1 120px"><label>IIBB</label><select id="add-ib" style="width:100%">'+IBOPS.map(o=>'<option>'+o+'</option>').join('')+'</select></div></div><div style="display:flex;gap:8px;justify-content:flex-end;margin-top:16px"><button class="btn-s" onclick="closeModal()">Cancelar</button><button class="btn" onclick="addClient()">Agregar</button></div>')}
function openEditModal(id){if(!isAdmin)return;const c=S.clients.find(x=>x.id===id);if(!c)return;openModal('<h3 style="color:#185FA5">Editar — '+c.n+'</h3><div class="form-row"><div class="form-group" style="flex:1 1 100%"><label>Razón Social</label><input type="text" id="ed-n" value="'+c.n+'" style="width:100%"></div></div><div class="form-row"><div class="form-group" style="flex:1 1 150px"><label>Analista</label><select id="ed-a" style="width:100%">'+ANALYSTS.map(a=>'<option'+(a===c.a?' selected':'')+'>'+a+'</option>').join('')+'</select></div><div class="form-group" style="flex:0 0 70px"><label>CUIT</label><input type="number" id="ed-c" value="'+c.c+'" min="0" max="9" style="width:100%"></div><div class="form-group" style="flex:0 0 70px"><label>Cierre</label><input type="number" id="ed-m" value="'+c.m+'" min="1" max="12" style="width:100%"></div><div class="form-group" style="flex:1 1 120px"><label>IIBB</label><select id="ed-ib" style="width:100%">'+IBOPS.map(o=>'<option'+(o===c.ib?' selected':'')+'>'+o+'</option>').join('')+'</select></div></div><div style="display:flex;gap:8px;margin-top:16px;justify-content:space-between"><button class="btn-d" onclick="delClient('+c.id+')">Eliminar</button><button class="btn" onclick="saveEditModal('+c.id+')">Guardar cambios</button></div>')}
function saveEditModal(id){if(!isAdmin)return;const n=document.getElementById("ed-n").value,a=document.getElementById("ed-a").value,c=parseInt(document.getElementById("ed-c").value)||0,m=parseInt(document.getElementById("ed-m").value)||12,ib=document.getElementById("ed-ib").value;if(!confirm("¿Guardar cambios del cliente?"))return;const cl=S.clients.find(x=>x.id===id);if(cl){cl.n=n;cl.a=a;cl.c=c;cl.m=m;cl.ib=ib;persist();closeModal();render()}}
function openYrCfg(){if(!isAdmin)return;openModal('<h3 style="color:#185FA5">Configurar Años</h3><p style="font-size:12px;color:#555;margin-bottom:14px">Definí el año actual y los 4 años del historial.</p><div class="form-row"><div class="form-group"><label>Año actual</label><input type="number" id="yr-cur" value="'+S.years.cur+'" style="width:100px"></div></div><div class="form-row"><div class="form-group"><label>Historial</label><div style="display:flex;gap:8px">'+S.years.hist.map((yr,i)=>'<input type="number" id="yr-h'+i+'" value="'+yr+'" style="width:80px">').join('')+'</div></div></div><div style="display:flex;gap:8px;justify-content:flex-end;margin-top:16px"><button class="btn-s" onclick="closeModal()">Cancelar</button><button class="btn" onclick="saveYears()">Guardar</button></div>')}

/* ─── HTML builders ─── */
function stSel(cid,ok,val){if(!isAdmin)return badge(val);return '<select class="status-sel" style="background:'+(val==="PRESENTADA"?"#d4edda":val==="ADEUDADA"?"#f8d7da":val==="N/C"?"#e9ecef":"#fff")+';color:'+(val==="PRESENTADA"?"#155724":val==="ADEUDADA"?"#721c24":val==="N/C"?"#6c757d":"#888")+'" onchange="cUpdO('+cid+',\''+ok+'\',\'cs\',this.value,\'status\')">'+STATS.map(s=>'<option value="'+s+'"'+(s===val?" selected":"")+'>'+(s||"—")+'</option>').join("")+'</select>'}
function stSelH(cid,ok,yr,val){if(!isAdmin)return badge(val);return '<select class="status-sel" style="background:'+(val==="PRESENTADA"?"#d4edda":val==="ADEUDADA"?"#f8d7da":val==="N/C"?"#e9ecef":"#fff")+';color:'+(val==="PRESENTADA"?"#155724":val==="ADEUDADA"?"#721c24":val==="N/C"?"#6c757d":"#888")+'" onchange="cUpdH('+cid+',\''+ok+'\','+yr+',this.value)">'+STATS.map(s=>'<option value="'+s+'"'+(s===(val||"")?" selected":"")+'>'+(s||"—")+'</option>').join("")+'</select>'}
function dateField(cid,ok,val){if(!isAdmin)return fmtD(val);const disp=dateToDisplay(val);return '<input type="text" class="date-input" placeholder="DD/MM/AAAA" value="'+disp+'" maxlength="10" oninput="handleDateInput(this,'+cid+',\''+ok+'\')" onblur="handleDateBlur(this,'+cid+',\''+ok+'\')">';}
function handleDateBlur(el,cid,ok){const v=el.value;if(!v)return;const iso=displayToDate(v);if(iso){confirmAndRun("¿Guardar fecha "+v+"?",()=>updO(cid,ok,"d",iso))}else{alert("Formato inválido. Usar DD/MM/AAAA.");const c=S.clients.find(x=>x.id===cid);el.value=dateToDisplay(c?.o[ok]?.d||"")}}
/* ═══ VIEWS ═══ */
function vDash(){const st=getStats();let dl=getDeadlines();if(S.dashFilt==="VENCIDO")dl=dl.filter(d=>d.d<0);else if(S.dashFilt==="URGENTE")dl=dl.filter(d=>d.d>=0&&d.d<=7);else if(S.dashFilt==="PROXIMO")dl=dl.filter(d=>d.d>7);
return '<h2 class="stitle">Dashboard — Presentaciones '+S.years.cur+'</h2><div class="kpi-row">'+[[S.clients.length,"Clientes","#E6F1FB","#0C447C"],[st.p,"Presentadas","#d4edda","#155724"],[st.a,"Adeudadas","#f8d7da","#721c24"],[st.s,"Sin dato","#FFF8EC","#854F0B"],[st.v,"Vencidos",st.v?"#f8d7da":"#d4edda",st.v?"#721c24":"#155724"],[st.p7,"Próx. 7d",st.p7?"#FFF8EC":"#d4edda",st.p7?"#854F0B":"#155724"]].map(([n,l,bg,c])=>'<div class="kpi" style="background:'+bg+'"><div class="kpi-num" style="color:'+c+'">'+n+'</div><div class="kpi-label">'+l+'</div></div>').join("")+'</div><div class="card"><div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;margin-bottom:10px"><h3 style="margin:0;font-size:14px;color:#185FA5">Próximos Vencimientos</h3><div style="display:flex;gap:4px;flex-wrap:wrap"><button class="obl-tab'+(S.dashFilt===""?" active":"")+'" onclick="S.dashFilt=\'\';render()">Todos</button><button class="obl-tab'+(S.dashFilt==="VENCIDO"?" active":"")+'" onclick="S.dashFilt=\'VENCIDO\';render()">Vencidos</button><button class="obl-tab'+(S.dashFilt==="URGENTE"?" active":"")+'" onclick="S.dashFilt=\'URGENTE\';render()">Urgentes (≤7d)</button><button class="obl-tab'+(S.dashFilt==="PROXIMO"?" active":"")+'" onclick="S.dashFilt=\'PROXIMO\';render()">Próximos (>7d)</button></div></div><div style="font-size:11px;color:#888;margin-bottom:8px">'+dl.length+' resultado'+(dl.length===1?"":"s")+(dl.length>20?" (mostrando 20)":"")+'</div><div style="overflow-x:auto"><table><thead><tr><th>Urg.</th><th>Cliente</th><th>Obligación</th><th>Vto.</th><th>Días</th><th>Status</th><th>Analista</th></tr></thead><tbody>'+dl.slice(0,20).map(d=>'<tr class="clickable" onclick="goDetail('+d.id+')"><td><span class="badge '+urgCls(d.d)+'" style="padding:2px 8px">'+urgLbl(d.d)+'</span></td><td style="font-weight:600">'+d.cn+'</td><td>'+d.ol+'</td><td>'+fmtD(d.dt)+'</td><td style="font-weight:600">'+(d.d<0?Math.abs(d.d)+"d vdo":d.d+"d")+'</td><td>'+badge(d.cs)+'</td><td style="font-size:11px;color:#555">'+d.a+'</td></tr>').join("")+'</tbody></table></div></div>'}

function vCl(){const fc=getFiltered();
return '<h2 class="stitle">Clientes — Control de Status '+S.years.cur+'</h2><div class="filter-bar"><input type="text" placeholder="Buscar..." value="'+S.search+'" oninput="S.search=this.value;render()"><select onchange="S.filtA=this.value;render()"><option value="">Analista</option>'+ANALYSTS.map(a=>'<option value="'+a+'"'+(S.filtA===a?" selected":"")+'>'+a+'</option>').join("")+'</select><select onchange="S.filtS=this.value;render()"><option value="">Status</option>'+STATS.slice(1).map(s=>'<option value="'+s+'"'+(S.filtS===s?" selected":"")+'>'+s+'</option>').join("")+'</select>'+((S.search||S.filtA||S.filtS)?'<button class="btn-s" onclick="S.search=\'\';S.filtA=\'\';S.filtS=\'\';render()">Limpiar</button>':"")+'<span style="font-size:11px;color:#888">'+fc.length+'</span>'+(isAdmin?'<div class="ml-auto"><button class="btn" onclick="openAddModal()">+ Agregar</button></div>':"")+'</div><div style="overflow-x:auto"><table><thead><tr><th>Cliente</th><th>CUIT</th><th>Cierre</th><th>IIBB</th><th>Analista</th>'+OBLS.map(k=>'<th style="font-size:9px;text-align:center">'+OLBL[k]+'</th>').join("")+(isAdmin?'<th style="text-align:center">Acc.</th>':"")+'</tr></thead><tbody>'+fc.map(c=>'<tr><td class="trunc clickable" style="font-weight:600" onclick="goDetail('+c.id+')">'+c.n+'</td><td style="text-align:center">'+c.c+'</td><td style="text-align:center">'+c.m+'</td><td style="font-size:10px">'+c.ib+'</td><td style="font-size:11px;color:#555">'+c.a.split(" ")[0]+'</td>'+OBLS.map(k=>'<td style="text-align:center">'+badge(c.o[k]?.cs)+'</td>').join("")+(isAdmin?'<td style="text-align:center"><button class="btn-s" style="padding:3px 8px;font-size:10px" onclick="openEditModal('+c.id+')">Editar</button></td>':"")+'</tr>').join("")+'</tbody></table></div>'}

function vDet(){const c=S.clients.find(x=>x.id===S.selId);if(!c)return"<p>No seleccionado.</p>";
let h='<button class="back-btn" onclick="go(\'clientes\')">← Volver</button><h2 class="stitle">Detalle del Cliente</h2><div class="card det-header"><div><h2>'+c.n+'</h2><div class="sub">Analista: <b>'+c.a+'</b> · CUIT: <b>'+c.c+'</b> · Cierre: <b>'+c.m+'</b> · IIBB: <b>'+c.ib+'</b></div></div>'+(isAdmin?'<button class="btn-s" onclick="openEditModal('+c.id+')">Editar</button>':"")+'</div>';
OBLS.forEach(k=>{const o=c.o[k];if(!o)return;const d=daysTo(o.d);
h+='<div class="card" style="margin-top:8px"><div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;margin-bottom:10px"><h3 style="margin:0;font-size:14px">'+OLBL[k]+'</h3>'+(o.d&&o.d!=="N/C"?'<span style="font-size:11px;color:'+(d<0?"#721c24":d<=30?"#854F0B":"#555")+'">Vto: '+fmtD(o.d)+' ('+(d<0?Math.abs(d)+"d vdo":d+"d")+')</span>':'<span style="font-size:11px;color:#888">N/C</span>')+'</div>';
h+='<div style="display:flex;gap:12px;flex-wrap:wrap"><div style="flex:1 1 180px"><label style="font-size:11px;font-weight:600;color:#555">Status '+S.years.cur+'</label><div style="margin-top:3px">'+stSel(c.id,k,o.cs)+'</div></div>';
h+='<div style="flex:1 1 300px"><label style="font-size:11px;font-weight:600;color:#555">Historial'+(isAdmin?" (editable)":"")+'</label><div class="hist-row">'+S.years.hist.map(yr=>'<div class="hist-col"><div class="yr">'+yr+'</div>'+stSelH(c.id,k,yr,o.y?.[yr]||"")+'</div>').join("")+'</div></div></div>';
if(o.nt)h+='<div class="note-box">📝 '+o.nt+'</div>';
if(isAdmin)h+='<div style="margin-top:8px"><input type="text" style="width:100%;max-width:500px" placeholder="Nota..." value="'+(o.nt||"")+'" onblur="cUpdNote('+c.id+',\''+k+'\',this)"></div>';
if(k==="ganancias"){h+='<div class="wf-box"><div class="wf-title">Workflow DJ</div><div class="wf-grid">'+WFSTEPS.map((s,i)=>'<div class="wf-item"><label>'+( i+1)+'. '+s+'</label>'+(isAdmin?'<select style="width:100%;font-size:10px;margin-top:2px" onchange="cUpdWf('+c.id+','+i+',this.value)">'+WFST.map(v=>'<option value="'+v+'"'+(v===(o.wf?.[i]||"")?" selected":"")+'>'+(v||"— Pend. —")+'</option>').join("")+'</select>':'<div style="margin-top:2px">'+badge(o.wf?.[i]||"")+'</div>')+'</div>').join("")+'</div></div>'}
if(k==="cm05"&&o.co!==undefined){h+='<div class="cm-box"><div class="cm-title">Coeficientes</div>'+(isAdmin?'<select onchange="cUpdO('+c.id+',\'cm05\',\'co\',this.value,\'coeficientes\')">'+["","EN PROCESO","TERMINADO","N/C"].map(v=>'<option value="'+v+'"'+(v===(o.co||"")?" selected":"")+'>'+(v||"— Pend. —")+'</option>').join("")+'</select>':badge(o.co))+'</div>'}
h+='</div>'});return h}

function vObl(){return '<h2 class="stitle">Vista por Obligación</h2><div class="obl-tabs">'+OBLS.map(k=>'<button class="obl-tab'+(S.oblF===k?" active":"")+'" onclick="S.oblF=\''+k+'\';render()">'+OLBL[k]+'</button>').join("")+'</div><div style="overflow-x:auto"><table><thead><tr><th>Cliente</th><th>Vto.</th><th>Días</th><th>'+S.years.cur+'</th>'+S.years.hist.map(yr=>'<th>'+yr+'</th>').join("")+'<th>Notas</th>'+(S.oblF==="ganancias"?"<th>WF</th>":"")+(S.oblF==="cm05"?"<th>Coef.</th>":"")+'</tr></thead><tbody>'+S.clients.map(c=>{const o=c.o[S.oblF];if(!o)return"";const d=daysTo(o.d);const wd=S.oblF==="ganancias"?(o.wf?.filter(s=>s==="TERMINADO").length||0):0;return'<tr class="clickable" onclick="goDetail('+c.id+')"><td class="trunc" style="font-weight:600">'+c.n+'</td><td>'+fmtD(o.d)+'</td><td>'+(o.d==="N/C"?"—":'<span style="color:'+(d<0?"#721c24":d<=30?"#854F0B":"#555")+';font-weight:600">'+(d<0?Math.abs(d)+"d vdo":d+"d")+'</span>')+'</td><td style="text-align:center">'+badge(o.cs)+'</td>'+S.years.hist.map(yr=>'<td style="text-align:center">'+badge(o.y?.[yr])+'</td>').join("")+'<td style="font-size:10px;max-width:150px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:#854F0B">'+(o.nt||"—")+'</td>'+(S.oblF==="ganancias"?'<td style="text-align:center"><span style="font-size:10px;font-weight:600;color:'+(wd===8?"#155724":"#854F0B")+'">'+wd+'/8</span></td>':"")+(S.oblF==="cm05"?'<td style="text-align:center">'+badge(o.co)+'</td>':"")+'</tr>'}).join("")+'</tbody></table></div>'}

function vVto(){return '<h2 class="stitle">Vencimientos — '+(isAdmin?"Editar Fechas":"Consulta")+'</h2><div class="obl-tabs">'+OBLS.map(k=>'<button class="obl-tab'+(S.oblF===k?" active":"")+'" onclick="S.oblF=\''+k+'\';render()">'+OLBL[k]+'</button>').join("")+'</div><div style="overflow-x:auto"><table><thead><tr><th>Cliente</th><th>CUIT</th><th>Cierre</th><th>IIBB</th><th>Fecha Vto.</th><th>Días</th>'+(isAdmin?'<th>Acción</th>':"")+'</tr></thead><tbody>'+S.clients.map(c=>{const o=c.o[S.oblF];if(!o)return"";const d=daysTo(o.d);const nc=o.d==="N/C";return'<tr><td style="font-weight:600">'+c.n+'</td><td style="text-align:center">'+c.c+'</td><td style="text-align:center">'+c.m+'</td><td style="font-size:11px">'+c.ib+'</td><td>'+(nc?'<span style="color:#888">N/C</span>':dateField(c.id,S.oblF,o.d))+'</td><td>'+(nc?"—":'<span style="color:'+(d<0?"#721c24":d<=30?"#854F0B":"#555")+';font-weight:600">'+(d<0?Math.abs(d)+"d vdo":d+"d")+'</span>')+'</td>'+(isAdmin?'<td>'+(nc?'<button class="btn-s" style="padding:3px 8px;font-size:10px" onclick="cToggleNC('+c.id+',\''+S.oblF+'\',false)">Habilitar</button>':'<button class="btn-s" style="padding:3px 8px;font-size:10px" onclick="cToggleNC('+c.id+',\''+S.oblF+'\',true)">N/C</button>')+'</td>':"")+'</tr>'}).join("")+'</tbody></table></div>'}

function vWf(){return '<h2 class="stitle">Workflow DJ Ganancias</h2><div style="overflow-x:auto"><table><thead><tr><th>Cliente</th>'+WFSTEPS.map((s,i)=>'<th style="font-size:9px;text-align:center;max-width:85px">'+(i+1)+'. '+s+'</th>').join("")+'<th style="text-align:center">%</th></tr></thead><tbody>'+S.clients.map(c=>{const wf=c.o.ganancias?.wf||[];const dn=wf.filter(s=>s==="TERMINADO").length;const pc=Math.round(dn/8*100);return'<tr><td class="trunc clickable" style="font-weight:600;font-size:11px" onclick="goDetail('+c.id+')">'+c.n+'</td>'+WFSTEPS.map((_,i)=>'<td style="text-align:center;padding:4px 2px">'+(isAdmin?'<select style="font-size:9px;padding:2px 3px;width:100%;background:'+(wf[i]==="TERMINADO"?"#d4edda":wf[i]==="EN PROCESO"?"#FFF8EC":"#fff")+'" onchange="cUpdWf('+c.id+','+i+',this.value)">'+WFST.map(v=>'<option value="'+v+'"'+(v===(wf[i]||"")?" selected":"")+'>'+(v||"—")+'</option>').join("")+'</select>':badge(wf[i]))+'</td>').join("")+'<td style="text-align:center"><div class="progress-bar"><div class="progress-track"><div class="progress-fill" style="width:'+pc+'%;background:'+(pc===100?"#28a745":"#EF9F27")+'"></div></div><span style="font-size:10px;font-weight:600;color:'+(pc===100?"#155724":"#854F0B")+';min-width:28px">'+pc+'%</span></div></td></tr>'}).join("")+'</tbody></table></div>'}

function vAn(){return '<h2 class="stitle">Vista por Analista</h2>'+ANALYSTS.map(a=>{const cs=S.clients.filter(c=>c.a===a);const ad=cs.reduce((ac,c)=>ac+OBLS.filter(k=>c.o[k]?.cs==="ADEUDADA").length,0);const pr=cs.reduce((ac,c)=>ac+OBLS.filter(k=>c.o[k]?.cs==="PRESENTADA").length,0);const pd=cs.reduce((ac,c)=>ac+OBLS.filter(k=>!c.o[k]?.cs).length,0);return'<div class="card" style="margin-bottom:16px"><div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px"><h4 style="margin:0;font-size:14px;color:#185FA5">'+a+'</h4><span style="font-size:12px;color:#555">'+cs.length+' clientes</span></div><div style="display:flex;gap:10px;margin-bottom:10px"><span style="font-size:12px"><b style="color:#155724">'+pr+'</b> pres.</span><span style="font-size:12px"><b style="color:#721c24">'+ad+'</b> adeud.</span><span style="font-size:12px"><b style="color:#854F0B">'+pd+'</b> s/dato</span></div><div style="overflow-x:auto"><table><thead><tr><th style="font-size:10px">Cliente</th>'+OBLS.map(k=>'<th style="font-size:9px;text-align:center">'+OLBL[k].split(" ")[0]+'</th>').join("")+'</tr></thead><tbody>'+cs.map(c=>'<tr class="clickable" onclick="goDetail('+c.id+')"><td style="font-size:11px;font-weight:600">'+c.n+'</td>'+OBLS.map(k=>'<td style="text-align:center">'+badge(c.o[k]?.cs)+'</td>').join("")+'</tr>').join("")+'</tbody></table></div></div>'}).join("")}

function init(){load();render()}
</script>
</body>
</html>